{
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 5,

    "modules-left": ["hyprland/workspaces", "custom/metar"],
    "modules-center": ["clock", "clock#1"],
    "modules-right": ["custom/bluetooth", "wireplumber", "custom/sunsetr", "memory", "cpu", "temperature", "tray"],
    "hyprland/workspaces": {
        "format": "<span size='larger'>{icon}</span>",
        "on-click": "activate",
        "format-icons": {
            "active": "\uf444",
            "default": "\uf4c3"
        },
        "icon-size": 10,
        "sort-by-number": true,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        }
    },

	"custom/bluetooth": {
		"format": "󰂯  ",
		"on-click": "kitty bluetui"
	},

	"custom/metar": {
		"format": "{text}",
		"tooltip": true,
		"exec": "$HOME/.config/waybar/metar_module/metar.sh KBNA",
		"return-type": "json",
		"on-click": "firefox https://www.windy.com/-Weather-radar-radar"
	},

	"custom/sunsetr": {
		"format": "\ue30d {text}K ",
		"tooltip": false,
		"interval": 60,
		"exec-on-event": true,
		"exec": "$HOME/.config/waybar/sunsetr_module/get_temp.sh",
		"on-scroll-up": "$HOME/.config/waybar/sunsetr_module/increase_temp.sh",
		"on-scroll-down": "$HOME/.config/waybar/sunsetr_module/decrease_temp.sh"
	},

    "clock": {
        "format": "{:%A %b %d - %H:%M:%S}L",
		"interval": 1,
		"tooltip": true,
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode"          : "year",
			"mode-mon-col"  : 3,
			"weeks-pos"     : "right",
			"on-scroll"     : 1,
			"on-click-right": "mode",
			"format": {
				"months":     "<span color='#ffead3'><b>{}</b></span>",
				"days":       "<span color='#ecc6d9'><b>{}</b></span>",
				"weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
				"weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
				"today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
			}
		}
    },
	
	"clock#1": {
		"timezone": "UTC",
        "format": " - {:%H:%M}Z",
		"tooltip": false
	},

    "wireplumber": {
        "format": "\udb81\udd7e {volume}%",
        "max-volume": 100,
        "scroll-step": 5,
		"on-click": "pavucontrol"
    },

	"cpu": {
		"interval": 2,
		"format": "CPU {usage}% ",
		"on-click": "kitty btop"
	},

    "temperature": {
		"interval": 10,
		"hwmon-path": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon4/temp1_input",
        "format": "{temperatureC}°"
    },

    "memory": {
        "interval": 10,
        "format": "{used:0.1f}/{total:0.1f}GB",
		"on-click": "kitty btop"
    },

    "network": {
        "format": "",
        "format-ethernet": "\udb83\udc9d",
        "format-wifi": "{icon}",
        "format-disconnected": "\udb83\udc9c",
        "format-icons": ["\udb82\udd2f", "\udb82\udd1f", "\udb82\udd22", "\udb82\udd25", "\udb82\udd28"],
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-disconnected": "Disconnected"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 16
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "\udb80\udd76",
            "deactivated": "\udb83\udfaa"
        }
    }
}

